#!name=iOS Location Spoofer (Stateless)
#!desc=任何售卖本项目/模块的都是骗子，请立即联系退款。无状态版：坐标写入每台设备各自的本机存储、可公开共用、多人互不覆盖。搭配选点页使用（点地图选位置 → 储存到设备）。适用于 Surge。
#!homepage=https://github.com/cyberhandyman/ios-location-spoofer

[Script]
# 拦截 /clls/wloc 响应，读本机持久化坐标替换；argument 不带经纬度/enabled，全交给设备端持久化（未选点 → 透传）。
iOS Location Spoofer = type=http-response,pattern=^https?:\/\/(?:gs-loc(?:-cn)?\.apple\.com|bluedot\.is\.autonavi\.com(?:\.gds\.alibabadns\.com)?)\/clls\/wloc(?:\?.*)?$,requires-body=1,binary-body-mode=1,max-size=1048576,timeout=10,script-path=https://raw.githubusercontent.com/cyberhandyman/ios-location-spoofer/main/location-spoofer.js,argument=mode=response&debug=false
# 拦截选点页储存请求，写入本机持久化。
iLS Settings = type=http-request,pattern=^https?:\/\/gs-loc(?:-cn)?\.apple\.com\/ils-settings\/,requires-body=0,max-size=0,timeout=10,script-path=https://raw.githubusercontent.com/cyberhandyman/ios-location-spoofer/main/location-settings.js

[MITM]
hostname = %APPEND% gs-loc.apple.com, gs-loc-cn.apple.com, bluedot.is.autonavi.com, bluedot.is.autonavi.com.gds.alibabadns.com
