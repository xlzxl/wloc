#!name=iOS Location Spoofer (Stateless)
#!desc=任何售卖本项目/模块的都是骗子，请立即联系退款。无状态版：坐标写入本机 $prefs、可公开共用、多人互不覆盖。QX 用「重写引用」(设置→重写→引用，需资源解析器)。MITM 主机名需手动加进 设置→MITM。
#!homepage=https://github.com/cyberhandyman/ios-location-spoofer

[rewrite_local]
^https?:\/\/(?:gs-loc(?:-cn)?\.apple\.com|bluedot\.is\.autonavi\.com(?:\.gds\.alibabadns\.com)?)\/clls\/wloc(?:\?.*)?$ url script-response-body https://raw.githubusercontent.com/cyberhandyman/ios-location-spoofer/main/location-spoofer-qx.js
^https?:\/\/gs-loc(?:-cn)?\.apple\.com\/ils-settings\/ url script-echo-response https://raw.githubusercontent.com/cyberhandyman/ios-location-spoofer/main/location-settings.js

[mitm]
hostname = gs-loc.apple.com, gs-loc-cn.apple.com, bluedot.is.autonavi.com, bluedot.is.autonavi.com.gds.alibabadns.com
